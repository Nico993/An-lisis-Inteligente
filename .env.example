# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-reemplazar-con-tu-key

# Modelo (default: openai/o3-mini — razonamiento; configurable)
OPENROUTER_MODEL=openai/o3-mini

# Opcional: URL del sitio para cabeceras OpenRouter
OPENROUTER_SITE_URL=http://localhost:3000

# Ruta al Excel dummy (por defecto busca el archivo en la raíz del proyecto)
# DATA_XLSX_PATH=/ruta/completa/al/archivo.xlsx

# Opcional: esfuerzo de razonamiento para modelos compatibles (p. ej. o3 en OpenRouter). Valores: low | medium | high
# OPENROUTER_REASONING_EFFORT=medium
